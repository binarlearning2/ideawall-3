# Supabase project URL (Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe for browser, restricted by RLS (Settings -> API -> anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY, bypasses RLS. Never expose to the client/browser.
# Used in: join-code resolution, sticky-note/poll-vote writes (participants have no Supabase Auth session).
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of the deployed app, used to build shareable join links (e.g. https://ideawall.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
